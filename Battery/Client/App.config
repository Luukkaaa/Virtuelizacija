<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<system.serviceModel>
		<bindings>
			<netTcpBinding>
				<binding name="TcpStreamingBinding" transferMode="Streamed" maxReceivedMessageSize="2147483647">
					<security mode="None" />
				</binding>
			</netTcpBinding>
		</bindings>
		<client>
			<endpoint address="net.tcp://localhost:8000/EisService"
					  binding="netTcpBinding"
					  bindingConfiguration="TcpStreamingBinding"
					  contract="Common.IEisService"
					  name="EisTcpEndpoint" />
		</client>
	</system.serviceModel>
</configuration>